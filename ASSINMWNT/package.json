{
  "name": "omnimise",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @omnimise/db generate",
    "db:migrate": "pnpm --filter @omnimise/db migrate:dev",
    "db:push": "pnpm --filter @omnimise/db db:push"
  },
  "devDependencies": {
    "turbo": "^1.13.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
